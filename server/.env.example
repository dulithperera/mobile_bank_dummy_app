# Get these from https://console.twilio.com after creating a free trial account
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Port the server runs on
PORT=4000

# Set to "true" to skip real SMS sending and just log OTPs to the server console
# Useful for testing without using up your 100 free Twilio SMS credits
DEV_MODE_NO_SMS=true
