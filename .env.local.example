# Twilio — leave blank and set DEV_MODE_NO_SMS=true to skip real SMS during testing
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# SMS_PROVIDER selects which SMS backend lib/sms.js uses: "aws" (default) or "textlk"
SMS_PROVIDER=aws

# AWS SNS (used when SMS_PROVIDER=aws)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Text.lk (used when SMS_PROVIDER=textlk) — get the token from app.text.lk
TEXTLK_API_TOKEN=
TEXTLK_SENDER_ID=TextLKDemo

# Set to "true" to print OTPs to the server console instead of sending SMS
DEV_MODE_NO_SMS=true

# Vercel KV — run `vercel env pull .env.local` after linking your project, or fill in manually
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

NEXT_PUBLIC_SUPABASE_URL=https://kzikfgcjceuldouoxmmn.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable__zjsUJcucgcACOZq3F2N_w_nJkv9e-6
